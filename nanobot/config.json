{
  "agents": {
    "defaults": {
      "workspace": "./workspace",
      "model": "qwen/qwen3.6-plus-preview:free",
      "provider": "openrouter",
      "maxTokens": 8192,
      "contextWindowTokens": 65536,
      "temperature": 0.1,
      "maxToolIterations": 40
    }
  },
  "providers": {
    "openrouter": {
      "apiKey": "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"
    }
  },
  "channels": {
    "webchat": {
      "enabled": true,
      "allowFrom": [
        "*"
      ]
    }
  },
  "tools": {
    "mcpServers": {
      "lms": {
        "command": "python",
        "args": [
          "-m",
          "mcp_lms"
        ],
        "env": {
          "NANOBOT_LMS_BACKEND_URL": "http://localhost:42002",
          "NANOBOT_LMS_API_KEY": "lab8-secret-key"
        }
      },
      "obs": {
        "command": "python",
        "args": [
          "-m",
          "mcp_obs"
        ]
      }
    }
  }
}