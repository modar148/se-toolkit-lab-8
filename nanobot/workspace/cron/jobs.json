{
  "version": 1,
  "jobs": [
    {
      "id": "health-check-1",
      "name": "LMS Health Check",
      "enabled": true,
      "schedule": {
        "kind": "every",
        "atMs": null,
        "everyMs": 900000,
        "expr": null,
        "tz": null
      },
      "payload": {
        "kind": "agent_turn",
        "message": "Check for LMS backend errors in the last 15 minutes using logs_error_count and logs_search. Post a short summary.",
        "deliver": true,
        "channel": "webchat",
        "to": "*"
      },
      "state": {
        "nextRunAtMs": null,
        "lastRunAtMs": null,
        "lastStatus": null,
        "lastError": null,
        "runHistory": []
      },
      "createdAtMs": 0,
      "updatedAtMs": 0,
      "deleteAfterRun": false
    }
  ]
}
