{
  "version": 1,
  "jobs": [
    {
      "id": "health-check-1",
      "name": "LMS Health Check",
      "enabled": true,
      "schedule": {
        "kind": "every",
        "every_ms": 900000
      },
      "payload": {
        "kind": "agent_turn",
        "message": "Check for LMS backend errors in the last 15 minutes using logs_error_count and logs_search. Post a short summary.",
        "deliver": true,
        "channel": "webchat",
        "to": "*"
      },
      "state": {},
      "created_at_ms": 0,
      "updated_at_ms": 0,
      "delete_after_run": false
    }
  ]
}